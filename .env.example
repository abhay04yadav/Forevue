# ==============================================================================
# Forevue — environment variable template
#
# Copy this file to `.env` and fill in real values for local development:
#     cp .env.example .env        (macOS/Linux)
#     Copy-Item .env.example .env (Windows PowerShell)
#
# RULES (Architecture Bible Ch8 §6, Ch10 §5):
#   - This file contains KEYS and SAFE PLACEHOLDERS ONLY. Never put real
#     secrets here.
#   - `.env` is git-ignored and must never be committed.
#   - In staging/production, these values are injected by the platform's
#     secret store at container start — never baked into an image or a CI log.
#
# This template reflects the configuration surface the backend expects. Values
# marked "(future)" are placeholders for capabilities on the roadmap (AI plane,
# Redis) and are not yet consumed by v1 code.
# ==============================================================================

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
APP_ENV=development            # development | staging | production
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR

# ------------------------------------------------------------------------------
# Database (PostgreSQL — the single system of record, with RLS)
#   DATABASE_URL            -> app role (app_user), NON-superuser, RLS applies.
#   MIGRATIONS_DATABASE_URL -> privileged/owner role for Alembic DDL only
#                              (CREATE ROLE / GRANT / ENABLE+FORCE RLS / CREATE
#                              POLICY). Falls back to DATABASE_URL locally.
#   APP_DB_PASSWORD         -> password the bootstrap migration assigns to
#                              app_user. Read only by migrations, never by the
#                              running app.
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://app_user:CHANGE_ME@localhost:5432/forevue
MIGRATIONS_DATABASE_URL=postgresql+psycopg://postgres:CHANGE_ME@localhost:5432/forevue
APP_DB_PASSWORD=CHANGE_ME

# ------------------------------------------------------------------------------
# Authentication (JWT access/refresh + Argon2 — TDR-15)
#   JWT_SECRET_KEY is the entire auth trust boundary. Generate a strong random
#   value per environment, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(48))"
# ------------------------------------------------------------------------------
JWT_SECRET_KEY=CHANGE_ME_GENERATE_A_STRONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ------------------------------------------------------------------------------
# CORS / frontend
#   Comma-separated list of allowed origins for the web client.
# ------------------------------------------------------------------------------
FRONTEND_ORIGINS=http://localhost:5173

# ------------------------------------------------------------------------------
# Redis (future — TDR-5: cache, rate-limit counters, refresh-token denylist)
# ------------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------------------------
# AI Gateway / LLM provider (future — TDR-7: vendor-agnostic gateway)
#   No service ever calls a provider SDK directly; all access is mediated by
#   the AI Gateway. Keys are injected here only where the gateway runs.
# ------------------------------------------------------------------------------
# AI_GATEWAY_PROVIDER=
# AI_GATEWAY_API_KEY=
# AI_GATEWAY_BASE_URL=

# ------------------------------------------------------------------------------
# Frontend (apps/web) — Vite reads VITE_-prefixed vars at build/dev time.
#   Keep frontend env in apps/web/.env.local in practice; shown here for
#   completeness.
# ------------------------------------------------------------------------------
# VITE_API_BASE_URL=http://localhost:8000
